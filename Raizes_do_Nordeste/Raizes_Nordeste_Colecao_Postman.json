{
  "info": {
    "name": "Raízes do Nordeste - Cenários de Teste",
    "_postman_id": "raizes-nordeste-collection-v1",
    "description": "Coleção de testes para a API do sistema Raízes do Nordeste. Inclui casos positivos e negativos para todas as funcionalidades principais.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "https://api.raizesnordeste.com.br/v1", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "pedido_id", "value": "", "type": "string" }
  ],
  "item": [

    {
      "name": "1. Autenticação",
      "item": [

        {
          "name": "TC01 - Login com sucesso",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function() { pm.response.to.have.status(200); });",
                  "pm.test('Retorna token JWT', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.token).to.be.a('string');",
                  "  pm.collectionVariables.set('token', json.token);",
                  "});",
                  "pm.test('Retorna dados do usuario', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.usuario.nome).to.eql('Ana Paula');",
                  "  pm.expect(json.usuario.pontos).to.be.a('number');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ana@email.com\",\n  \"senha\": \"123456\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },

        {
          "name": "TC02 - Login com senha errada (negativo)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401 Unauthorized', function() { pm.response.to.have.status(401); });",
                  "pm.test('Mensagem de erro presente', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.erro).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ana@email.com\",\n  \"senha\": \"senhaerrada\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },

        {
          "name": "TC03 - Login com campos vazios (negativo)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 Bad Request', function() { pm.response.to.have.status(400); });",
                  "pm.test('Retorna erro de validacao', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.erro).to.include('obrigatório');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"\",\n  \"senha\": \"\"\n}" },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },

        {
          "name": "TC04 - Cadastro com sucesso + aceite LGPD",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', function() { pm.response.to.have.status(201); });",
                  "pm.test('Retorna ID do novo usuario', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.id).to.be.a('string');",
                  "  pm.expect(json.lgpd_aceito).to.eql(true);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"João Silva\",\n  \"email\": \"joao@email.com\",\n  \"senha\": \"senha123\",\n  \"lgpd_aceito\": true\n}"
            },
            "url": { "raw": "{{base_url}}/auth/cadastro", "host": ["{{base_url}}"], "path": ["auth", "cadastro"] }
          }
        },

        {
          "name": "TC05 - Cadastro sem aceitar LGPD (negativo)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 422 Unprocessable Entity', function() { pm.response.to.have.status(422); });",
                  "pm.test('Erro informa consentimento LGPD obrigatorio', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.erro.toLowerCase()).to.include('lgpd');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Maria\",\n  \"email\": \"maria@email.com\",\n  \"senha\": \"abc123\",\n  \"lgpd_aceito\": false\n}"
            },
            "url": { "raw": "{{base_url}}/auth/cadastro", "host": ["{{base_url}}"], "path": ["auth", "cadastro"] }
          }
        }

      ]
    },

    {
      "name": "2. Cardápio",
      "item": [

        {
          "name": "TC06 - Listar cardápio por unidade (Recife)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function() { pm.response.to.have.status(200); });",
                  "pm.test('Retorna array de produtos', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.produtos).to.be.an('array');",
                  "  pm.expect(json.produtos.length).to.be.above(0);",
                  "});",
                  "pm.test('Cada produto tem campos obrigatorios', function() {",
                  "  var json = pm.response.json();",
                  "  json.produtos.forEach(function(p) {",
                  "    pm.expect(p).to.have.property('id');",
                  "    pm.expect(p).to.have.property('nome');",
                  "    pm.expect(p).to.have.property('preco');",
                  "    pm.expect(p).to.have.property('categoria');",
                  "  });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/cardapio?unidade=recife",
              "host": ["{{base_url}}"],
              "path": ["cardapio"],
              "query": [{ "key": "unidade", "value": "recife" }]
            }
          }
        },

        {
          "name": "TC07 - Filtrar cardápio por categoria",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function() { pm.response.to.have.status(200); });",
                  "pm.test('Todos os produtos sao da categoria sucos', function() {",
                  "  var json = pm.response.json();",
                  "  json.produtos.forEach(function(p) {",
                  "    pm.expect(p.categoria).to.eql('sucos');",
                  "  });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/cardapio?unidade=recife&categoria=sucos",
              "host": ["{{base_url}}"],
              "path": ["cardapio"],
              "query": [
                { "key": "unidade", "value": "recife" },
                { "key": "categoria", "value": "sucos" }
              ]
            }
          }
        },

        {
          "name": "TC08 - Unidade inexistente (negativo)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 Not Found', function() { pm.response.to.have.status(404); });",
                  "pm.test('Mensagem de erro', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.erro).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/cardapio?unidade=londrina",
              "host": ["{{base_url}}"],
              "path": ["cardapio"],
              "query": [{ "key": "unidade", "value": "londrina" }]
            }
          }
        }

      ]
    },

    {
      "name": "3. Pedidos",
      "item": [

        {
          "name": "TC09 - Realizar pedido com sucesso",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 Created', function() { pm.response.to.have.status(201); });",
                  "pm.test('Retorna ID do pedido', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.pedido_id).to.be.a('string');",
                  "  pm.collectionVariables.set('pedido_id', json.pedido_id);",
                  "});",
                  "pm.test('Status inicial eh confirmado', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('confirmado');",
                  "});",
                  "pm.test('Total calculado corretamente', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.total).to.be.a('number');",
                  "  pm.expect(json.total).to.be.above(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unidade\": \"recife\",\n  \"itens\": [\n    { \"produto_id\": 1, \"quantidade\": 2 },\n    { \"produto_id\": 3, \"quantidade\": 1 }\n  ],\n  \"pagamento\": \"pix\"\n}"
            },
            "url": { "raw": "{{base_url}}/pedidos", "host": ["{{base_url}}"], "path": ["pedidos"] }
          }
        },

        {
          "name": "TC10 - Pedido com carrinho vazio (negativo)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 Bad Request', function() { pm.response.to.have.status(400); });",
                  "pm.test('Erro: carrinho vazio', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.erro.toLowerCase()).to.include('vazio');",
