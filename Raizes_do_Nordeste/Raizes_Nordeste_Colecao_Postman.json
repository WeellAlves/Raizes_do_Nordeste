    {
      "name": "4. Pagamento (Integração Externa)",
      "item": [

        {
          "name": "TC15 - Solicitar pagamento via Pix (positivo)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function() { pm.response.to.have.status(200); });",
                  "pm.test('Retorna chave pix ou QR code', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.qr_code || json.chave_pix).to.be.a('string');",
                  "});",
                  "pm.test('Status eh pendente', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.status_pagamento).to.eql('pendente');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pedido_id\": \"{{pedido_id}}\",\n  \"metodo\": \"pix\",\n  \"valor\": 29.00\n}"
            },
            "url": { "raw": "{{base_url}}/pagamento/solicitar", "host": ["{{base_url}}"], "path": ["pagamento", "solicitar"] }
          }
        },

        {
          "name": "TC16 - Pagamento negado (simulado, negativo)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 402 Payment Required', function() { pm.response.to.have.status(402); });",
                  "pm.test('Mensagem de pagamento negado', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.status_pagamento).to.eql('negado');",
                  "  pm.expect(json.motivo).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pedido_id\": \"{{pedido_id}}\",\n  \"metodo\": \"cartao_credito\",\n  \"valor\": 29.00,\n  \"simular_falha\": true\n}"
            },
            "url": { "raw": "{{base_url}}/pagamento/solicitar", "host": ["{{base_url}}"], "path": ["pagamento", "solicitar"] }
          }
        }

      ]
    },

    {
      "name": "5. Fidelidade",
      "item": [

        {
          "name": "TC17 - Consultar pontos do usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function() { pm.response.to.have.status(200); });",
                  "pm.test('Retorna saldo de pontos', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.pontos).to.be.a('number');",
                  "  pm.expect(json.pontos).to.be.at.least(0);",
                  "});"
