            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unidade\": \"recife\",\n  \"itens\": [],\n  \"pagamento\": \"pix\"\n}"
            },
            "url": { "raw": "{{base_url}}/pedidos", "host": ["{{base_url}}"], "path": ["pedidos"] }
          }
        },

        {
          "name": "TC11 - Pedido sem forma de pagamento (negativo)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400 Bad Request', function() { pm.response.to.have.status(400); });",
                  "pm.test('Erro informa pagamento obrigatorio', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.erro.toLowerCase()).to.include('pagamento');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"unidade\": \"recife\",\n  \"itens\": [{ \"produto_id\": 1, \"quantidade\": 1 }],\n  \"pagamento\": \"\"\n}"
            },
            "url": { "raw": "{{base_url}}/pedidos", "host": ["{{base_url}}"], "path": ["pedidos"] }
          }
        },

        {
          "name": "TC12 - Consultar status do pedido",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 OK', function() { pm.response.to.have.status(200); });",
                  "pm.test('Retorna status valido', function() {",
                  "  var json = pm.response.json();",
                  "  var statusValidos = ['confirmado', 'em_preparo', 'pronto', 'retirado', 'cancelado'];",
                  "  pm.expect(statusValidos).to.include(json.status);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/pedidos/{{pedido_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["pedidos", "{{pedido_id}}", "status"]
            }
          }
        },

        {
          "name": "TC13 - Pedido ID inexistente (negativo)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 Not Found', function() { pm.response.to.have.status(404); });",
                  "pm.test('Erro: pedido nao encontrado', function() {",
                  "  var json = pm.response.json();",
                  "  pm.expect(json.erro).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base_url}}/pedidos/PEDIDO-INEXISTENTE-999/status",
              "host": ["{{base_url}}"],
              "path": ["pedidos", "PEDIDO-INEXISTENTE-999", "status"]
            }
          }
        },

        {
          "name": "TC14 - Listar historico de pedidos do usuario",
          "event": [
