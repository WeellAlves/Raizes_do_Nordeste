          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/pedidos/meus", "host": ["{{base_url}}"], "path": ["pedidos", "meus"] }
          }
        }

