          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base_url}}/fidelidade/pontos", "host": ["{{base_url}}"], "path": ["fidelidade", "pontos"] }
          }
        },

